{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": { 
            "runtime": "vercel-php@0.9.0" 
        }
    },
    "outputDirectory": "public",
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
    
    }
}